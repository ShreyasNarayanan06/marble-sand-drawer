void HAL_UART_RxCpltCallback(UART_HandleTypeDef *huart) {
    if (huart->Instance == USART1) {
        if (rx_index == 0 && (rx_byte == 0xAA || rx_byte == 0xAB)) {
            rx_buffer[0] = rx_byte;
            rx_index++;
        } else if (rx_index > 0) {
            rx_buffer[rx_index++] = rx_byte;
            if (rx_index == 5) {
                uart_flag = 1;
                rx_index = 0;
            }
        }
        HAL_UART_Receive_IT(&huart1, &rx_byte, 1);
    }
}
